# Claw-Empire — variáveis de ambiente
# Copiar para .env e preencher os valores

# Obrigatório — chave de criptografia para tokens OAuth e messenger (AES-256-GCM)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_SECRET=

# Fallback legacy (pode ser igual ao OAUTH_ENCRYPTION_SECRET)
SESSION_SECRET=

# Segredo para o webhook /api/inbox
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INBOX_WEBHOOK_SECRET=

# Token Bearer para acesso remoto à API (recomendado quando exposto fora do loopback)
# Gerar com: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
API_AUTH_TOKEN=

# Bind address dentro do container (não alterar)
HOST=0.0.0.0
PORT=8790

# Caminhos internos do container (não alterar)
DB_PATH=/app/data/claw-empire.sqlite
LOGS_DIR=/app/data/logs

# OAuth GitHub (opcional)
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# OAuth Google (opcional)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# OpenAI (opcional, para Codex)
# OPENAI_API_KEY=
