# Paperclip — variáveis de ambiente
# Copiar para .env e preencher os valores

# Obrigatório — gerar com: openssl rand -hex 32
BETTER_AUTH_SECRET=

# URL pública do Paperclip
PAPERCLIP_PUBLIC_URL=https://paperclip.bewiser.com.br

# API key enviada ao proxy copilot-api (identifica a origem da chamada)
ANTHROPIC_API_KEY=paperclip@orthanc

# UID/GID do usuário saruman no host
PAPERCLIP_UID=1001
PAPERCLIP_GID=1001