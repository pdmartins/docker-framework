# Hindsight — variáveis de ambiente
# Copiar para .env e preencher os valores

# Obrigatório — senha do banco
HINDSIGHT_DB_PASSWORD=

# Opcional — versão (default: latest)
# HINDSIGHT_VERSION=latest

# Opcional — usuário e nome do banco (defaults abaixo)
# HINDSIGHT_DB_USER=hindsight_user
# HINDSIGHT_DB_NAME=hindsight_db

# LLM provider (default: anthropic via copilot-api local)
# Para usar outro provider, descomentar e preencher:
# HINDSIGHT_API_LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
