#!/usr/bin/env bash
# hooks/post-commit
#
# Após cada commit, gera zips compactados (máxima compressão, partes de 5MB)
# das pastas volumes/ que pertencem aos diretórios tocados pelo commit.
# Cria um commit separado por volume em .backup-volumes/{nome}/
#
# Não roda se o commit atual já for um backup (evita loop infinito).
# Log em tempo real: .backup-volumes/backup.log

set -uo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
BACKUP_DIR="${REPO_ROOT}/.backup-volumes"
LOG_FILE="${BACKUP_DIR}/backup.log"

mkdir -p "$BACKUP_DIR"

log() {
  local msg="[$(date '+%H:%M:%S')] $*"
  echo "$msg"
  echo "$msg" >> "$LOG_FILE"
}

# Evita loop: sai se o último commit já é um backup automático
last_msg=$(git log -1 --pretty=%s)
if [[ "$last_msg" == chore:\ backup\ volumes\ -\ * ]]; then
  exit 0
fi

# Descobre quais diretórios têm volumes/ e foram tocados por este commit
declare -A DIRS_TO_BACKUP
while IFS= read -r changed_file; do
  dir=$(dirname "$changed_file")
  for check_dir in "$dir" "$(dirname "$dir")"; do
    [[ "$check_dir" == "." ]] && continue
    if [[ -d "${REPO_ROOT}/${check_dir}/volumes" ]]; then
      DIRS_TO_BACKUP["$check_dir"]=1
    fi
  done
done < <(git diff-tree --no-commit-id -r --name-only HEAD)

if [[ ${#DIRS_TO_BACKUP[@]} -eq 0 ]]; then
  exit 0
fi

log "========================================"
log "Commit: $(git log -1 --pretty='%h %s')"
log "Volumes a processar: ${#DIRS_TO_BACKUP[@]}"
log "========================================"

# Busca pastas "volumes/" em até 4 níveis de profundidade
while IFS= read -r -d '' volumes_dir; do
  # Pula volumes vazios
  if [[ -z "$(ls -A "$volumes_dir" 2>/dev/null)" ]]; then
    log "Ignorando volume vazio: $volumes_dir"
    continue
  fi

  rel_volumes=$(realpath --relative-to="$REPO_ROOT" "$volumes_dir")  # ex: platform/sonarqube/volumes
  parent_rel=$(dirname "$rel_volumes")                                 # ex: platform/sonarqube
  parent_abs=$(dirname "$volumes_dir")

  # Só processa se o pai foi tocado pelo commit atual
  if [[ -z "${DIRS_TO_BACKUP[$parent_rel]+x}" ]]; then
    log "Pulando (não alterado neste commit): $parent_rel"
    continue
  fi

  # Nome base do zip e pasta de destino dentro de .backup-volumes/
  base_name="${parent_rel//\//-}-volumes"   # ex: platform-sonarqube-volumes
  dest_dir="${BACKUP_DIR}/${base_name}"

  log "Iniciando backup: $rel_volumes → .backup-volumes/${base_name}/"

  # Limpa partes antigas para evitar arquivos obsoletos (.z01, .z02, etc.)
  rm -rf "$dest_dir"
  mkdir -p "$dest_dir"

  # Cria zip com máxima compressão (-9) e split de 5MB (-s 5m)
  # cd no dest_dir é necessário: zip cria os .z01/.z02 no diretório corrente
  # Exit code 18 = arquivos sem permissão (esperado em volumes Docker) — trata como aviso
  log "Compactando... (pode demorar para volumes grandes)"
  zip_output=$(cd "$dest_dir" && zip -r -9 -s 5m "${base_name}.zip" "${parent_abs}/volumes/" 2>&1)
  zip_exit=$?

  if [[ $zip_exit -eq 0 ]]; then
    size=$(du -sh "$dest_dir" | cut -f1)
    log "OK: .backup-volumes/${base_name}/ (${size})"
  elif [[ $zip_exit -eq 18 ]]; then
    size=$(du -sh "$dest_dir" | cut -f1)
    log "AVISO: alguns arquivos sem permissão foram ignorados em $rel_volumes (${size})"
  else
    log "ERRO ao criar zip de $rel_volumes (exit $zip_exit):"
    log "$zip_output"
    continue
  fi

  # Adiciona apenas esta pasta de backup e cria um commit dedicado
  git add "${dest_dir}"
  git commit -m "chore: backup volumes - ${parent_rel}"
  log "Commit criado: backup volumes - ${parent_rel}"
  log "----------------------------------------"

done < <(find "$REPO_ROOT" -maxdepth 4 -type d -name "volumes" \
         -not -path "*/.git/*" \
         -not -path "*/.backup-volumes/*" \
         -print0)

log "Backup concluído."
